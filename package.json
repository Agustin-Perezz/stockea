{
  "name": "svelte-tamplate",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "test": "npx supabase db reset && playwright test",
    "test:ui": "npx supabase db reset && playwright test --ui",
    "test:ci": "playwright test",
    "test:show-report": "npx monocart show-report ./coverage/e2e/monocart-report.html",
    "coverage:show-report": "npx monocart show-report ./coverage/e2e/v8/index.html",
    "supabase:gen-types": "supabase gen types typescript --project-id=$SUPABASE_PROJECT_ID --schema public > src/lib/domain/types/database.types.ts",
    "supabase:gen-types:local": "supabase gen types typescript --local --schema public > src/lib/domain/types/database.types.ts",
    "db:generate": "drizzle-kit generate",
    "db:introspect": "drizzle-kit introspect"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.8.0",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "bits-ui": "^2.17.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "monocart-reporter": "^2.10.1",
    "postgres": "^3.4.9",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "supawright": "^0.4.2",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "lint-staged": {
    "*.{js,ts,svelte,css}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@sentry/sveltekit": "^10.49.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "axios": "^1.15.0",
    "svelte-french-toast": "^1.2.0",
    "sveltekit-superforms": "^2.30.1",
    "zod": "^4.3.6"
  }
}
